# ============================================================
# APP
# ============================================================
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
API_URL=http://localhost:8000
FRONTEND_URL=http://localhost:5173

# ============================================================
# DATABASE (PostgreSQL)
# ============================================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=tinder_devs
DATABASE_URL=postgresql+asyncpg://postgres:postgres@db:5432/tinder_devs

# Для локальной разработки (без Docker)
# DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/tinder_devs

# ============================================================
# REDIS
# ============================================================
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# Для локальной разработки (без Docker)
# REDIS_URL=redis://localhost:6379/0

# ============================================================
# JWT (JSON Web Tokens)
# ============================================================
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60*24
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# ============================================================
# MINIO (S3-compatible storage)
# ============================================================
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=uploads
MINIO_USE_SSL=false

# Для локальной разработки (без Docker)
# MINIO_ENDPOINT=localhost:9000

# ============================================================
# ML (Machine Learning)
# ============================================================
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIM=384
EMBEDDING_BATCH_SIZE=32
EMBEDDING_DEVICE=cpu
# EMBEDDING_DEVICE=cuda  # если есть GPU

# ============================================================
# CORS (Cross-Origin Resource Sharing)
# ============================================================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# ============================================================
# LOGGING
# ============================================================
LOG_LEVEL=INFO
# LOG_LEVEL=DEBUG  # для детальной отладки

# ============================================================
# SENTRY (опционально, для отслеживания ошибок)
# ============================================================
SENTRY_DSN=
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0

# ============================================================
# EMAIL (опционально, для отправки уведомлений)
# ============================================================
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@tinder-devs.com
SMTP_USE_TLS=true